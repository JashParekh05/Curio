OPENAI_API_KEY=your_openai_api_key
TRANSCRIPT_API_KEY=your_transcriptapi_dot_com_key

# --- LLM model selection ---
# Standard model used by every LLM call site (centralized via llm.resolve_model).
# Defaults to gpt-4o when unset. Set to gpt-4o-mini to roll back instantly.
LLM_MODEL=gpt-4o
# Optional stronger model used only by the hardest reasoning steps (curriculum
# build, coherence, segment judging). When unset/blank, the strong tier falls
# back to LLM_MODEL (no accidental upgrade).
# STRONG_MODEL=

# --- YouTube Data API v3 keys ---
# Quota is per Google Cloud PROJECT (10,000 units/day each; a search costs 100
# units, so ~100 searches/day per project). To scale past one project's daily
# limit, create multiple Google Cloud projects, enable "YouTube Data API v3" on
# each, mint an API key per project, and list them in YT_PROJECTS as a
# comma-separated set of project_id:api_key pairs. The pool tracks per-project
# usage and fails over to the next affordable project when one hits its cap.
#   YT_PROJECTS=curio-yt-01:AIzaKEY1...,curio-yt-02:AIzaKEY2...,curio-yt-03:AIzaKEY3...
YT_PROJECTS=project_id_1:your_youtube_data_api_v3_key_1,project_id_2:your_youtube_data_api_v3_key_2
# Legacy single-key fallback: used as one project named "default" only when
# YT_PROJECTS is unset/empty. Prefer YT_PROJECTS above for multi-project scaling.
YOUTUBE_API_KEY=your_youtube_data_api_v3_key

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_secret_key   # "Secret key" from Dashboard → Settings → API Keys (NOT the Publishable key)
ALLOWED_ORIGINS=https://your-frontend.vercel.app  # comma-separated list of allowed CORS origins

# --- Engagement telemetry ---
# Comma-separated Supabase user ids (the JWT `sub` claim) allowed to read
# cross-user telemetry views (session journeys for any user, all-user rollups).
# Non-operators can still read only their own sessions. Leave empty to grant
# no one operator access. Find a user's id in Supabase: Dashboard → Authentication
# → Users (the "UID" column), or decode the `sub` claim of their access token.
OPERATOR_USER_IDS=uuid-of-operator-1,uuid-of-operator-2
